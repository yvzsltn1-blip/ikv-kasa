rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin kontrolü: hardcoded email VEYA metadata/admins listesinde
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'yvzsltn61@gmail.com' ||
        (exists(/databases/$(database)/documents/metadata/admins) &&
         request.auth.token.email in get(/databases/$(database)/documents/metadata/admins).data.emails)
      );
    }

    // Her kullanıcı sadece kendi verisini okuyup yazabilir, admin herkesi okuyup silebilir
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Kullanıcı adı kontrolü ve oluşturma
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Global eşya paylaşımı
    match /globalItems/{itemId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Global efsun önerileri (tüm kullanıcılar okur/yazar)
    match /metadata/enchantments {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Admin listesi: sadece admin okuyabilir/yazabilir
    match /metadata/admins {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Arama limitleri: herkes okuyabilir, sadece admin yazabilir
    match /metadata/searchLimits {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Diğer tüm yolları kapat
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
